# Local development — point at the backend running on your machine.
NEXT_PUBLIC_API_URL=http://localhost:5001

# Production note: no env var is required on the deployed frontend. When the
# app is served from profirmo.com / www.profirmo.com, services/api.js
# automatically routes every API call to https://proapi.profirmo.com (EC2,
# nginx, Let's Encrypt). To point a build at a non-prod backend, set
# NEXT_PUBLIC_API_URL on the deploy target.
