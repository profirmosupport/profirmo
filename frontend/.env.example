# Profirmo frontend env template.
# Copy to `.env.local` for local development; on prod hosts (Vercel / Render
# static frontend) set these as Environment Variables in the host UI.
#
# All NEXT_PUBLIC_* vars are baked into the client bundle at `next build`
# time — they are visible to the browser. Never put secrets in here.

# Backend base URL. In production this is set to the prod backend host;
# in dev it should point at your local backend port.
NEXT_PUBLIC_API_URL=http://localhost:5001

# Canonical site URL — used by /blog metadata fallbacks. Optional in dev.
# NEXT_PUBLIC_SITE_URL=https://profirmo.com

# Razorpay public key — same value as backend RAZORPAY_KEY_ID. The KEY_SECRET
# must stay server-side; never expose it here.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_Sv712xZRztlXUq

# --- Firebase Phone Auth (client-side) --------------------------------------
# From the Firebase Console:
#   Project Settings -> General -> Your apps -> Web app -> SDK setup.
# The values are public by design (they're embedded in the JS bundle).
# Phone Auth must be enabled in Authentication -> Sign-in method, and the
# app's domain must be added to Authorized domains there.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
