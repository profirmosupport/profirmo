PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
JWT_SECRET=replace_with_secure_secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_DAYS=30

# MySQL database connection
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=demo_project_db
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_DIALECT=mysql
DB_SSL=false

# Phase-6: jobs / email / notifications
APP_URL=http://localhost:3000
EMAIL_FROM=Profirmo <no-reply@profirmo.com>
# Email delivery mode: dev | smtp
EMAIL_TRANSPORT=dev
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_SECURE=false
JOB_POLL_MS=4000
EMAIL_VERIFICATION_EXPIRY_HOURS=48

# Razorpay — Standard Checkout + signature verification.
# KEY_ID is also exposed to the frontend as NEXT_PUBLIC_RAZORPAY_KEY_ID.
# KEY_SECRET stays server-side; never put it in any NEXT_PUBLIC_* var.
RAZORPAY_KEY_ID=rzp_test_Sv712xZRztlXUq
RAZORPAY_KEY_SECRET=6U7qwvjtxpU1V2UxdRCbSnHd
RAZORPAY_WEBHOOK_SECRET=
PLATFORM_FEE_BPS=1000

# --- Firebase Phone Auth (server-side ID-token verification) ----------------
# Get these from the Firebase Console:
#   Project Settings -> Service accounts -> Generate new private key (JSON).
# The downloaded JSON has fields `project_id`, `client_email`, `private_key`.
# When pasting the private key into a .env file, the embedded newlines must
# be escaped as \n (the firebase.js init un-escapes them at startup).
#
# Either set the three split vars below, OR set FIREBASE_SERVICE_ACCOUNT to
# the full JSON blob — the latter is convenient on hosts that have a single
# "secret" field per env var (Render, Vercel).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...",...}'
