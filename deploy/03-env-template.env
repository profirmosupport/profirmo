# Backend env for EC2. Place at /etc/profirmo/backend.env before
# running 02-app.sh. Permissions: chmod 600. Owner: root or ubuntu.
#
# Values marked "REPLACE" should be reset to a fresh production
# secret — do NOT reuse the development JWT secret in production.
# The other values match what the local backend/.env already uses.

PORT=5001
NODE_ENV=production
FRONTEND_URL=https://profirmo.com
APP_URL=https://proapi.profirmo.com

# CORS allowlist for the deployed frontend(s).
CORS_ORIGINS=https://profirmo.com,https://www.profirmo.com,https://profirmo.onrender.com

# JWT — generate a fresh 64-char random secret for production.
# openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_FRESH_64CHAR_HEX
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_DAYS=365

# RDS MySQL (already running, ap-south-1)
DB_HOST=profirmo-rds-instance.cp8yy2i22afc.ap-south-1.rds.amazonaws.com
DB_PORT=3306
DB_NAME=profirmo_db
DB_USER=adminmasteruser
DB_PASSWORD=Hashmasterconnect321
DB_DIALECT=mysql
DB_SSL=false

# Email — Resend SMTP
EMAIL_FROM=Profirmo <no-reply@profirmo.com>
EMAIL_TRANSPORT=smtp
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_Sk9P6EUi_5Jpf9PTkTfBgSazNCBpm3yFu
SMTP_SECURE=true
JOB_POLL_MS=4000
EMAIL_VERIFICATION_EXPIRY_HOURS=48

# Razorpay (currently test keys — replace with live before launch)
RAZORPAY_KEY_ID=rzp_test_Sv712xZRztlXUq
RAZORPAY_KEY_SECRET=6U7qwvjtxpU1V2UxdRCbSnHd
RAZORPAY_WEBHOOK_SECRET=
PLATFORM_FEE_BPS=1000

# S3 storage values live encrypted in admin_settings table; nothing to set here.
